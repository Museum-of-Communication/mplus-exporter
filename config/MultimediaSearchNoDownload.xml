<!--
Request body for Module Search. Returns all IDs of multimedia assets where
- modification date of either multimedia asset or linked object is younger than given date
- 'Inv. Status' of linked object (MulReferencesCre.MulObjectRef.ObjRecordingStatusVoc) is 'veröffentlicht' (205009)
- 'Typ' (MulTypeVoc) is 'Bild' (31041)
- 'Status' (MulStatusVoc) is not 'intern' (150337)
- Right Types do NOT allow for img download (MulRightsGrp.TypeVoc is NOT 233017, 233014, 233013 OR 233016)

-->
<application xmlns="http://www.zetcom.com/ria/ws/module/search">
    <modules>
        <module name="Multimedia">
            <search>
                <select>
                    <field fieldPath="__id"/>
                </select>
                <expert>
                    <and>
                        <or>
                            <greaterEquals fieldPath="__lastModified" operand="{timestamp}"/>
                            <greaterEquals fieldPath="MulReferencesCre.MulObjectRef.__lastModified" operand="{timestamp}"/>
                        </or>
                        <and>
                            <equalsField fieldPath="MulReferencesCre.MulObjectRef.ObjRecordingStatusVoc" operand="205009"/>
                            <equalsField fieldPath="MulTypeVoc" operand="31041"/>
                            <notEqualsField fieldPath="MulStatusVoc" operand="150337"/>
                        </and>
                        <or>
                            <notEqualsField fieldPath="MulRightsGrp.TypeVoc" operand="233017"/>
                            <notEqualsField fieldPath="MulRightsGrp.TypeVoc" operand="233014"/>
                            <notEqualsField fieldPath="MulRightsGrp.TypeVoc" operand="233013"/>
                            <notEqualsField fieldPath="MulRightsGrp.TypeVoc" operand="233016"/>
                        </or>
                    </and>
                </expert>
            </search>
        </module>
    </modules>
</application>
